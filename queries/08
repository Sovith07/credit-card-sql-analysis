Which city took least number of days to reach its 500th transaction after the first transaction in that city 

with cte as( select *,row_number() over(partition by city order by transaction_date,transaction_id) as rn from credit_card_transactions),
cte_2 as select city,min(transaction_date) as transaction_1,max(transaction_date) as transaction_500,datediff(day,min(transaction_date), max(transaction_date)) as date_diff from cte where rn in(1,500) 
group by city having count(*)=2 order by date_diff desc
